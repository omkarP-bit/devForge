{
  "name": "devforge",
  "version": "1.0.0",
  "description": "Automated CI/CD Pipeline Generator and Deployment Automation Tool",
  "main": "dist/index.js",
  "bin": {
    "devforge": "dist/cli/index.js"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "prepare": "husky install"
  },
  "save-exact": true,
  "dependencies": {
    "chalk": "4.1.2",
    "cli-table3": "0.6.5",
    "commander": "12.1.0",
    "inquirer": "8.2.7",
    "ora": "5.4.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "19.3.0",
    "@commitlint/config-conventional": "19.2.2",
    "@types/jest": "29.5.12",
    "@types/node": "20.12.12",
    "@typescript-eslint/eslint-plugin": "7.10.0",
    "@typescript-eslint/parser": "7.10.0",
    "eslint": "8.57.0",
    "eslint-plugin-n": "17.7.0",
    "eslint-plugin-security": "2.1.1",
    "husky": "9.0.11",
    "jest": "29.7.0",
    "lint-staged": "15.2.5",
    "prettier": "3.2.5",
    "ts-jest": "29.1.4",
    "typescript": "5.4.5"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
