{
  "name": "@apurvv28/devforge",
  "version": "2.1.0",
  "description": "Automated CI/CD Pipeline Generator and Deployment Automation Tool",
  "main": "dist/index.js",
  "bin": {
    "devforge": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "scripts": {
    "pretest": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "bench": "ts-node benchmarks/init.bench.ts",
    "audit": "npm audit --audit-level=high",
    "lint": "eslint src --ext .ts",
    "prepare": "husky install",
    "postinstall": "",
    "prepublishOnly": "npm run lint && npm run test:coverage && npm run build && npm audit --audit-level=high && node dist/cli/index.js --version",
    "release": "semantic-release"
  },
  "save-exact": true,
  "dependencies": {
    "@anthropic-ai/sdk": "0.54.0",
    "@aws-sdk/client-bedrock-runtime": "3.1063.0",
    "@google/generative-ai": "0.24.1",
    "@elastic/elasticsearch": "8.11.0",
    "@langchain/anthropic": "1.0.0",
    "@langchain/aws": "1.0.0",
    "@langchain/core": "1.1.48",
    "@langchain/google-genai": "1.0.0",
    "@langchain/langgraph": "1.3.6",
    "@langchain/openai": "1.0.0",
    "chalk": "4.1.2",
    "cli-table3": "0.6.5",
    "commander": "12.1.0",
    "diff": "5.2.2",
    "inquirer": "8.2.7",
    "ioredis": "5.6.1",
    "js-yaml": "4.2.0",
    "openai": "5.3.0",
    "ora": "5.4.1",
    "uuid": "9.0.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "19.3.0",
    "@commitlint/config-conventional": "19.2.2",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "6.0.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "10.0.1",
    "@semantic-release/npm": "12.0.1",
    "@semantic-release/release-notes-generator": "14.0.3",
    "@types/inquirer": "8.2.10",
    "@types/jest": "29.5.12",
    "@types/js-yaml": "4.0.9",
    "@types/node": "20.12.12",
    "@typescript-eslint/eslint-plugin": "7.10.0",
    "@typescript-eslint/parser": "7.10.0",
    "cli-highlight": "2.1.11",
    "conventional-changelog-conventionalcommits": "8.0.0",
    "eslint": "8.57.0",
    "eslint-plugin-n": "17.7.0",
    "eslint-plugin-security": "2.1.1",
    "husky": "9.0.11",
    "jest": "29.7.0",
    "lint-staged": "15.5.2",
    "prettier": "3.2.5",
    "semantic-release": "23.1.1",
    "tinybench": "2.5.1",
    "ts-jest": "29.1.4",
    "ts-node": "10.9.2",
    "typescript": "5.4.5"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
